#!/usr/bin/env dash

# Disable C-s freezing the terminal
stty -ixon

# Enter/exit zellij automatically
if [ -z "$INSIDE_EMACS" ] && [ -z "$ZELLIJ" ]; then
    if [ "$ZELLIJ_AUTO_ATTACH" = "true" ]; then
        zellij attach -c
    else
        zellij
    fi

    if [ "$ZELLIJ_AUTO_EXIT" = "true" ]; then
        exit
    fi
fi

exec nu
